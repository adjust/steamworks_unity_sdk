# OS X
.DS_Store

# Unity generated
unity/Example/[Ll]ibrary/
unity/Example/[Tt]emp/
unity/Example/[Oo]bj/
unity/Example/[Bb]uild/
unity/Example/[Bb]uilds/
unity/Example/[Ll]ogs/
unity/Example/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
unity/Example/[Mm]emoryCaptures/

# Recordings can get excessive in size
unity/Example/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# unity/Example/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
unity/Example/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
unity/Example/ExportedObj/
unity/Example/.consulo/
unity/Example/*.csproj
unity/Example/*.unityproj
unity/Example/*.sln
unity/Example/*.suo
unity/Example/*.tmp
unity/Example/*.user
unity/Example/*.userprefs
unity/Example/*.pidb
unity/Example/*.booproj
unity/Example/*.svd
unity/Example/*.pdb
unity/Example/*.mdb
unity/Example/*.opendb
unity/Example/*.VC.db

# Unity3D generated meta files
unity/Example/*.pidb.meta
unity/Example/*.pdb.meta
unity/Example/*.mdb.meta

# Unity3D generated file on crash reports
unity/Example/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
unity/Example/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
