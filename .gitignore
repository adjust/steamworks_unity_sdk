# OS X
.DS_Store

# Unity generated
Example/[Ll]ibrary/
Example/[Tt]emp/
Example/[Oo]bj/
Example/[Bb]uild/
Example/[Bb]uilds/
Example/[Ll]ogs/
Example/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
Example/[Mm]emoryCaptures/

# Recordings can get excessive in size
Example/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!Example/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# Example/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
Example/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
Example/ExportedObj/
Example/.consulo/
Example/*.csproj
Example/*.unityproj
Example/*.sln
Example/*.suo
Example/*.tmp
Example/*.user
Example/*.userprefs
Example/*.pidb
Example/*.booproj
Example/*.svd
Example/*.pdb
Example/*.mdb
Example/*.opendb
Example/*.VC.db

# Unity3D generated meta files
Example/*.pidb.meta
Example/*.pdb.meta
Example/*.mdb.meta

# Unity3D generated file on crash reports
Example/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
Example/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
